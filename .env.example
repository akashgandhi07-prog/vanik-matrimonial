# Copy to .env and set values from Supabase → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Data migration (scripts/migrate_matrimonial_register.py) — service role bypasses RLS
# SUPABASE_URL=                 # optional; falls back to VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=               # optional; use with --send-welcome-emails (same as Edge Functions)

# Edge Function secrets (set in Supabase Dashboard → Edge Functions → Secrets):
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=   # Resend webhook signing secret (Svix)
# PUBLIC_SITE_URL=https://vanikmatrimonial.co.uk
# ADMIN_NOTIFY_EMAIL=
# ADMIN_DIGEST_EMAIL=      # Falls back to ADMIN_NOTIFY_EMAIL
# CRON_SECRET=             # Optional; if set, scheduled HTTP calls must send header x-cron-secret
#
# Stripe (optional — when STRIPE_SECRET_KEY + STRIPE_MEMBERSHIP_PRICE_ID are set, registration requires
# payment unless a valid coupon is used; renewals use Checkout + webhook):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_MEMBERSHIP_PRICE_ID=price_...   # One-time GBP price (e.g. £10) in Stripe Dashboard
# STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe → Developers → Webhooks → endpoint signing secret
# Point the webhook URL to: https://<project>.supabase.co/functions/v1/stripe-webhook
# Events: checkout.session.completed
