# Copy to .env and set values from Supabase → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Must match the canonical URL users see (same as Supabase Auth "Site URL" and Edge PUBLIC_SITE_URL).
VITE_PUBLIC_SITE_URL=https://matrimonial.vanikcouncil.uk

# Optional: call Edge Functions via your domain (fixes ad blockers that block *.supabase.co).
# Uses Vite dev proxy `/bff/functions` → Supabase `/functions/v1`; production needs `vercel.json` rewrite—update destination ref there if not foltwnahxqlijbwtkhih.
# VITE_SUPABASE_FUNCTIONS_BFF_PREFIX=/bff/functions

# Data migration (scripts/migrate_matrimonial_register.py) - service role bypasses RLS
# SUPABASE_URL=                 # optional; falls back to VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=               # optional; use with --send-welcome-emails (same as Edge Functions)

# Edge Function secrets (set in Supabase Dashboard → Edge Functions → Secrets):
# Transactional mail (approvals, reminders, etc.): prefer SMTP (same as Auth custom SMTP) — set these on Edge; Dashboard Auth SMTP is separate.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM_EMAIL=youraddress@gmail.com   # Optional; defaults to SMTP_USER
# SMTP_FROM_NAME=Vanik Matrimonial Register
# SMTP_REPLY_TO=ops@example.com           # Optional Reply-To (e.g. council inbox)
# RESEND_API_KEY=                         # Optional fallback if SMTP not set; requires verified domain in Resend
# RESEND_FROM_EMAIL=notifications@your-verified-domain.com
# RESEND_FROM_NAME=Vanik Matrimonial Register
# RESEND_WEBHOOK_SECRET=   # Resend webhook signing secret (Svix)
# PUBLIC_SITE_URL=https://matrimonial.vanikcouncil.uk   # Required for correct email links; CORS also allows legacy Vercel + this host by default
# CORS_ALLOWED_ORIGINS=          # Optional: extra origins (e.g. https://www.matrimonial.vanikcouncil.uk) comma-separated
# CORS_ALLOW_VERCEL=1            # Optional: allow any https://*.vercel.app origin (set to 0 to disable)
# ADMIN_NOTIFY_EMAIL=
# ADMIN_DIGEST_EMAIL=      # Falls back to ADMIN_NOTIFY_EMAIL
# CRON_SECRET=             # Required for scheduled jobs (expire-memberships, reminders, etc.): callers must send x-cron-secret
#
# Stripe (optional - when STRIPE_SECRET_KEY + STRIPE_MEMBERSHIP_PRICE_ID are set, registration requires
# payment unless a valid coupon is used; renewals use Checkout + webhook):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_MEMBERSHIP_PRICE_ID=price_...   # One-time GBP price (e.g. £10) in Stripe Dashboard
# STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe → Developers → Webhooks → endpoint signing secret
# Point the webhook URL to: https://<project>.supabase.co/functions/v1/stripe-webhook
# Events: checkout.session.completed
